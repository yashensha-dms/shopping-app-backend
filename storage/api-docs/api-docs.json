                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter by status",
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "ids",
                        "in": "query",
                        "description": "Filter by IDs, comma-separated",
                        "schema": {
                            "type": "string"
