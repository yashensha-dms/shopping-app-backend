        "/product": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Get list of products",
                "description": "Returns paginated list of products with optional filters",
                "operationId": "getProducts",
                "parameters": [
                    {
                        "name": "paginate",
                        "in": "query",
                        "description": "Number of items per page",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "category",
                        "in": "query",
                        "description": "Filter by category slug(s), comma-separated",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "tag",
                        "in": "query",
                        "description": "Filter by tag slug(s), comma-separated",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "min",
                        "in": "query",
                        "description": "Minimum price filter",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "max",
                        "in": "query",
                        "description": "Maximum price filter",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "rating",
                        "in": "query",
                        "description": "Filter by rating(s), comma-separated",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "sortBy",
                        "in": "query",
                        "description": "Sort by: asc, desc, a-z, z-a, high-to-low, low-to-high",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "store_id",
                        "in": "query",
                        "description": "Filter by store ID",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter by status",
                        "schema": {
                            "type": "boolean"
                        }
